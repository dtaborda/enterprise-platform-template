# ─────────────────────────────────────────────────────────────────────────────
# Enterprise Platform Template - Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────────────────────

# Public API URL — exposed to the browser (NEXT_PUBLIC_ prefix)
# Local dev: http://127.0.0.1:54331 (port set in supabase/config.toml)
# Production: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331

# Anonymous (public) key — safe to expose in the browser
# Get from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SECRET, server-side only, NEVER expose to the browser
# Get from: Supabase Dashboard → Project Settings → API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection (Supabase Transaction pooler, port 6543)
# Used by Drizzle Kit (studio, introspect) — NOT for runtime queries.
# Format: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres

# ─────────────────────────────────────────────────────────────────────────────
# App Configuration
# ─────────────────────────────────────────────────────────────────────────────

# Base URL of the app — used for absolute URL generation (emails, redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App display name — shown in emails and UI
NEXT_PUBLIC_APP_NAME=My Enterprise App

# Environment name — used for logging and monitoring
# Values: development | test | production
NEXT_PUBLIC_APP_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Email (Resend)
# ─────────────────────────────────────────────────────────────────────────────

# Resend API key (SECRET, server-side only)
# Get from: https://resend.com
RESEND_API_KEY=

# From address used for all outgoing emails
EMAIL_FROM=noreply@yourdomain.com

# ─────────────────────────────────────────────────────────────────────────────
# Sentry (error monitoring) - Optional
# ─────────────────────────────────────────────────────────────────────────────

# Sentry DSN — public, safe to expose in the browser
# Get from: Sentry Dashboard → Project → Settings → SDK Setup → DSN
# NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token — for source map upload during build (SECRET)
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# SENTRY_AUTH_TOKEN=

# Sentry organization slug
# SENTRY_ORG=

# Sentry project slug
# SENTRY_PROJECT=

# ─────────────────────────────────────────────────────────────────────────────
# E2E Testing (used by Playwright tests — credentials from supabase/seed.sql)
# ─────────────────────────────────────────────────────────────────────────────

E2E_EMAIL=admin@enterprise.dev
E2E_PASSWORD=password123

# ─────────────────────────────────────────────────────────────────────────────
# Vercel (auto-injected — do NOT set manually)
# ─────────────────────────────────────────────────────────────────────────────

# VERCEL_GIT_COMMIT_SHA=
# VERCEL_URL=
# VERCEL_ENV=